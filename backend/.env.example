# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-hex-string

# Admin password for the /admin dashboard (default user: admin)
ADMIN_PASSWORD=safegate123

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev default: http://localhost:4200
# Production example: https://safegate.vercel.app
FRONTEND_URL=http://localhost:4200
